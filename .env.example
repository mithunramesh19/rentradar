# Database
DATABASE_URL=postgresql+asyncpg://rentradar:rentradar@localhost:5432/rentradar
DATABASE_URL_SYNC=postgresql://rentradar:rentradar@localhost:5432/rentradar

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Maps
GOOGLE_MAPS_API_KEY=your_key_here

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# SendGrid
SENDGRID_API_KEY=your_key_here
SENDGRID_FROM_EMAIL=alerts@rentradar.app

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scraper
SCRAPER_MAX_WORKERS=3
SCRAPER_REQUEST_DELAY_MIN=2.0
SCRAPER_REQUEST_DELAY_MAX=5.0

# ATTOM Data (Sprint 9 — optional)
ATTOM_API_KEY=your_key_here

# RentCast (Sprint 8 — optional)
RENTCAST_API_KEY=your_key_here
